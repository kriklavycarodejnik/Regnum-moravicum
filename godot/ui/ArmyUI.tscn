[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/ArmyUI.gd" id="1"]

[node name="ArmyUI" type="VBoxContainer"]
anchors_preset = 0
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 8
script = ExtResource("1")

[node name="Header" type="Label" parent="."]
layout_mode = 2
theme_type_variation = &"SubtitleLabel"
text = "Armády"

[node name="ArmyList" type="VBoxContainer" parent="."]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 4

[node name="ArmyInfo" type="Label" parent="."]
layout_mode = 2
autowrap_mode = 3
text = "Vyber armádu zo zoznamu."

[node name="Actions" type="HBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 6

[node name="MoveButton" type="Button" parent="Actions"]
custom_minimum_size = Vector2(0, 48)
layout_mode = 2
size_flags_horizontal = 3
text = "Presunúť"

[node name="BattleButton" type="Button" parent="Actions"]
custom_minimum_size = Vector2(0, 48)
layout_mode = 2
size_flags_horizontal = 3
text = "Bitka"

[node name="SiegeButton" type="Button" parent="Actions"]
custom_minimum_size = Vector2(0, 48)
layout_mode = 2
size_flags_horizontal = 3
text = "Obliehať"
